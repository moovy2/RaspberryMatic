# enable DRM/HDMI
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_GEM_DMA_HELPER=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_DISPLAY_HDMI_HELPER=y
CONFIG_DRM_DISPLAY_HDMI_STATE_HELPER=y
CONFIG_DRM_VC4=y
CONFIG_HDMI=y

# enable basic sound config (required for vc4)
CONFIG_SOUND=y
CONFIG_SND=y
CONFIG_SND_SOC=y

# disable old framebuffer for video display to work
# CONFIG_FB_BCM2708 is not set

# disable rpisense framebuffer (does not compile with kernel 6.18.x)
# CONFIG_FB_RPISENSE is not set

# disable sound
# CONFIG_SND_BCM2835 is not set

# disable video camera support
# CONFIG_VIDEO_BCM2835_UNICAM is not set

# disable touchscreen
# CONFIG_REGULATOR_RASPBERRYPI_TOUCHSCREEN_ATTINY is not set

# enable mmc support
CONFIG_MMC_BCM2835=y

# use pl011 serial as a kernel module and
# disable serial console on amba
CONFIG_SERIAL_AMBA_PL011=m
# CONFIG_SERIAL_AMBA_PL011_CONSOLE is not set

# nvme support
CONFIG_NVME_CORE=y
CONFIG_BLK_DEV_NVME=y

# disable backlight support
# CONFIG_BACKLIGHT_RPI is not set
