# Rockchip RK3399 specific kernel config fragment for Tinker Board 2
CONFIG_I2C=y
CONFIG_I2C_RK3X=y
CONFIG_DRM=y
CONFIG_DRM_ROCKCHIP=y
CONFIG_ROCKCHIP_VOP=y
CONFIG_ROCKCHIP_DW_HDMI=y
CONFIG_DRM_DW_HDMI=y
CONFIG_DRM_DW_HDMI_CEC=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_DISPLAY_HELPER=y
CONFIG_DRM_DISPLAY_DP_HELPER=y
CONFIG_DRM_DISPLAY_HDMI_HELPER=y
CONFIG_DRM_DISPLAY_HDMI_STATE_HELPER=y
# IOMMU needed by VOP (display controller) - without it VOP probe defers
CONFIG_ROCKCHIP_IOMMU=y
CONFIG_IOMMU_DMA=y
# RK808 PMIC provides HDMI regulators (avdd-0v9 / avdd-1v8)
CONFIG_MFD_RK8XX_I2C=y
CONFIG_REGULATOR_RK808=y
# virtual terminal and framebuffer console for HDMI text output
CONFIG_VT=y
CONFIG_VT_CONSOLE=y
CONFIG_VT_HW_CONSOLE_BINDING=y
CONFIG_FB=y
CONFIG_FB_DEVICE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y
