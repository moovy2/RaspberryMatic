#!/bin/sh
# shellcheck shell=dash disable=SC2169,SC3010,SC3036

STARTPWD=$(pwd)
BOOT_FS=boot.vfat.gz
ROOT_FS=rootfs.ext4.gz

# check that this is a rpi3 and nothing else
PLATFORM=$(grep PLATFORM= /VERSION | cut -d= -f2)
if [[ "${PLATFORM}" != "rpi3" ]]; then
  echo "ERROR: (PLATFORM != rpi3)<br/>"
  exit 1
fi

RC=1
if [[ -f "${STARTPWD}/${BOOT_FS}" ]]; then
  BOOT_DEV=$(/bin/mount | grep "/bootfs" | cut -f1 -d" ")
  if [[ -n "${BOOT_DEV}" ]]; then
    # backup extraconfig.txt before overwriting bootfs
    EXTRACONFIG_BACKUP=""
    if [[ -f "/bootfs/extraconfig.txt" ]]; then
      echo -ne "Backing up extraconfig.txt... "
      if cp /bootfs/extraconfig.txt /tmp/extraconfig.txt.bak; then
        echo "OK<br/>"
        EXTRACONFIG_BACKUP=/tmp/extraconfig.txt.bak
      else
        echo "WARNING: backup of extraconfig.txt failed, file will not be preserved<br/>"
      fi
    else
      echo "INFO: no extraconfig.txt found on bootfs, nothing to preserve<br/>"
    fi
    echo -ne "Writing bootfs to ${BOOT_DEV}... "
    /bin/umount -f /bootfs
    if ! zcat "${STARTPWD}/${BOOT_FS}" | /bin/dd of="${BOOT_DEV}" bs=1M conv=fsync; then
      echo "ERROR: (dd)"
      RC=1
    else
      echo "OK<br/>"
      RC=0
    fi
    /bin/mount /bootfs
    # restore extraconfig.txt after bootfs overwrite
    if [[ -n "${EXTRACONFIG_BACKUP}" ]] && [[ -f "${EXTRACONFIG_BACKUP}" ]]; then
      echo -ne "Restoring extraconfig.txt... "
      if cp "${EXTRACONFIG_BACKUP}" /bootfs/extraconfig.txt && chmod 0644 /bootfs/extraconfig.txt; then
        echo "OK<br/>"
        rm -f "${EXTRACONFIG_BACKUP}"
      else
        echo "WARNING: restore of extraconfig.txt failed, backup remains at ${EXTRACONFIG_BACKUP} for manual recovery<br/>"
      fi
    fi
  else
    echo "ERROR: no /bootfs found<br/>"
    RC=1
  fi
else
  echo "INFO: no bootfs update found, OK<br/>"
fi

if [[ -f "${STARTPWD}/${ROOT_FS}" ]]; then
  ROOT_DEV=$(/bin/mount | grep "/rootfs" | cut -f1 -d" ")
  if [[ -n "${ROOT_DEV}" ]]; then
    ROOT_PART_SIZE=$(/sbin/blockdev --getsize64 "${ROOT_DEV}" 2>/dev/null)
    ROOT_IMG_SIZE=$(/bin/gzip -l "${STARTPWD}/${ROOT_FS}" 2>/dev/null | awk 'NR==2 {print $2}')

    if [[ -z "${ROOT_PART_SIZE}" ]] || [[ -z "${ROOT_IMG_SIZE}" ]] || [[ "${ROOT_IMG_SIZE}" -le 0 ]]; then
      echo "ERROR: (rootfs size detection failed: partition=${ROOT_PART_SIZE:-unset}, image=${ROOT_IMG_SIZE:-unset})<br/>"
      RC=1
    elif [[ "${ROOT_PART_SIZE}" -ne "${ROOT_IMG_SIZE}" ]]; then
      STAGED_ROOT_FS=/usr/local/tmp/rootfs.ext4.gz
      echo -ne "Scheduling rootfs handoff to recoveryfs (${ROOT_PART_SIZE} != ${ROOT_IMG_SIZE})... "
      if ! mount -o rw,remount /userfs >/dev/null 2>&1; then
        echo "ERROR: (remount /userfs rw)<br/>"
        RC=1
      elif ! cp -f "${STARTPWD}/${ROOT_FS}" "${STAGED_ROOT_FS}"; then
        echo "ERROR: (cp ${STAGED_ROOT_FS})<br/>"
        RC=1
      elif ! ln -sfn "${STAGED_ROOT_FS}" /usr/local/.firmwareUpdate; then
        rm -f "${STAGED_ROOT_FS}" >/dev/null 2>&1 || true
        echo "ERROR: (ln /usr/local/.firmwareUpdate)<br/>"
        RC=1
      elif ! touch /usr/local/.recoveryMode; then
        rm -f "${STAGED_ROOT_FS}" >/dev/null 2>&1 || true
        rm -f /usr/local/.firmwareUpdate >/dev/null 2>&1 || true
        echo "ERROR: (touch /usr/local/.recoveryMode)<br/>"
        RC=1
      else
        sync
        mount -o ro,remount /userfs >/dev/null 2>&1 || true
        echo "OK, rebooting to recoveryfs<br/>"
        RC=0
        /sbin/reboot
        exit 0
      fi
      mount -o ro,remount /userfs >/dev/null 2>&1 || true
    else
      echo -ne "Writing rootfs to ${ROOT_DEV}... "
      /bin/umount -f /rootfs
      if ! zcat "${STARTPWD}/${ROOT_FS}" | /bin/dd of="${ROOT_DEV}" bs=1M conv=fsync; then
        echo "ERROR: (dd)"
        RC=1
      else
        echo "OK<br/>"
        RC=0
      fi
      /bin/mount /rootfs
    fi
  else
    echo "ERROR: not /rootfs found<br/>"
    RC=1
  fi
else
  echo "INFO: no rootfs update found, OK<br/>"
fi

exit ${RC}
